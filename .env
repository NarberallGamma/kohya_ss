# Порт Kohya GUI (7860 внутри контейнера). По умолчанию 7861 — не пересекается с SD WebUI на 7860.
KOHYA_PORT=7861

# TensorBoard (опционально: ./run.sh up-all)
TENSORBOARD_PORT=6006

# Хост-путь к models (Stable-diffusion/, Lora/, VAE/). Относительно каталога kohya_ss.
# При другом расположении WebUI задайте абсолютный путь (в WSL: /mnt/d/...).
MODELS_HOST_PATH=../stable-diffusion-webui-docker/data/models
